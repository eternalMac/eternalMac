{
  "name": "eternalmac-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:write": "node scripts/render-social-assets.mjs --write",
    "assets:sync": "node scripts/render-social-assets.mjs --sync-public",
    "assets:check": "node scripts/render-social-assets.mjs --check",
    "test:social-assets": "node --test scripts/test/social-assets.test.mjs",
    "dev": "astro dev --host 127.0.0.1",
    "prebuild": "npm run assets:sync",
    "build": "astro build",
    "docs:build": "npm run assets:sync && astro build",
    "preview": "astro preview --host 127.0.0.1"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.1",
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@expo-google-fonts/ibm-plex-mono": "0.4.1",
    "@expo-google-fonts/inter": "0.4.2",
    "@resvg/resvg-js": "2.6.2"
  }
}
